# ─────────────────────────────────────────────────────────
# AI Hustle Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real keys.
# ─────────────────────────────────────────────────────────

# Anthropic API — required for live AI tool demos
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — optional, enables "Sign in with Google"
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=

# Supabase — optional, for auth + database
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Site config
SITE_URL=http://localhost:3000
